{
  "metadata": [
    {
      "src": [
        {
          "src": "..",
          "files": [
            "**/*.csproj"
          ],
          "exclude": [
            "**/bin/**",
            "**/obj/**"
          ]
        }
      ],
      "dest": "api"
    }
  ],
  "build": {
    "content": [
      {
        "files": [
          "index.md",
          "**/toc.yml",
          "articles/**/*.md",
          "quality/**/*.md",
          "api/**/*.yml",
          "mutation/**/*.md"
        ]
      }
    ],
    "resource": [
      {
        "files": [
          "images/**",
          "examples/**"
        ]
      }
    ],
    "dest": "_site",
    "template": [
      "default",
      "modern"
    ],
    "globalMetadata": {
      "_appName": "ASI Backbone",
      "_appTitle": "ASI Backbone Documentation",
      "_appLogoPath": "images/logo.png",
      "_appFaviconPath": "images/favicon.ico",
      "_enableSearch": true
    }
  }
}
