<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <IsPackable>true</IsPackable>
    <PackageId>CDCavell.AsiBackbone.Templates</PackageId>
    <Title>CDCavell.AsiBackbone.Templates</Title>
    <Description>dotnet new templates for Accountable Systems Infrastructure governed ASP.NET Core hosts.</Description>
    <PackageTags>accountable-systems-infrastructure;asi-backbone;dotnet;governance;templates;dotnet-new;aspnetcore;webapi;endpoint-governance</PackageTags>
    <PackageType>Template</PackageType>
    <PackageReadmeFile>README.md</PackageReadmeFile>
    <IncludeBuildOutput>false</IncludeBuildOutput>
    <SuppressDependenciesWhenPacking>true</SuppressDependenciesWhenPacking>
    <NoDefaultExcludes>true</NoDefaultExcludes>
    <NoWarn>$(NoWarn);NU5128</NoWarn>
  </PropertyGroup>

  <ItemGroup>
    <Compile Remove="templates/**/*.cs" />
    <Content Include="templates/**/*" Exclude="templates/**/bin/**;templates/**/obj/**" Pack="true" PackagePath="content/" />
    <None Update="README.md" Pack="true" PackagePath="/" />
  </ItemGroup>

</Project>
