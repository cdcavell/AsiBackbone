<Project Sdk="Microsoft.NET.Sdk.Web">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <ManagePackageVersionsCentrally>false</ManagePackageVersionsCentrally>
    <IsPackable>false</IsPackable>
    <PackageId>Company.AsibackboneTemplate</PackageId>
    <UserSecretsId>Company.AsibackboneTemplate-local-dev</UserSecretsId>
  </PropertyGroup>

  <PropertyGroup>
    <AsiBackboneRepositorySourceRoot>../../..</AsiBackboneRepositorySourceRoot>
    <UseRepositoryAsiBackboneProjects Condition="Exists('$(AsiBackboneRepositorySourceRoot)/CDCavell.AsiBackbone.Core/CDCavell.AsiBackbone.Core.csproj')">true</UseRepositoryAsiBackboneProjects>
  </PropertyGroup>

  <ItemGroup Condition="'$(UseRepositoryAsiBackboneProjects)' == 'true'">
    <ProjectReference Include="$(AsiBackboneRepositorySourceRoot)/CDCavell.AsiBackbone.AspNetCore/CDCavell.AsiBackbone.AspNetCore.csproj" />
    <ProjectReference Include="$(AsiBackboneRepositorySourceRoot)/CDCavell.AsiBackbone.Core/CDCavell.AsiBackbone.Core.csproj" />
    <ProjectReference Include="$(AsiBackboneRepositorySourceRoot)/CDCavell.AsiBackbone.Storage.InMemory/CDCavell.AsiBackbone.Storage.InMemory.csproj" />
    <ProjectReference Include="$(AsiBackboneRepositorySourceRoot)/CDCavell.AsiBackbone.Analyzers/CDCavell.AsiBackbone.Analyzers.csproj" OutputItemType="Analyzer" ReferenceOutputAssembly="false" PrivateAssets="all" />
  </ItemGroup>

  <ItemGroup Condition="'$(UseRepositoryAsiBackboneProjects)' != 'true'">
    <PackageReference Include="CDCavell.AsiBackbone.AspNetCore" Version="1.2.0" />
    <PackageReference Include="CDCavell.AsiBackbone.Core" Version="1.2.0" />
    <PackageReference Include="CDCavell.AsiBackbone.Storage.InMemory" Version="1.2.0" />
    <PackageReference Include="CDCavell.AsiBackbone.Analyzers" Version="1.2.0" PrivateAssets="all" />
  </ItemGroup>

</Project>
