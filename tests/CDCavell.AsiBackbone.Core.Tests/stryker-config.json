{
  "stryker-config": {
    "solution": "../../AsiBackbone.slnx",
    "project": "CDCavell.AsiBackbone.Core.csproj",
    "target-framework": "net10.0",
    "configuration": "Release",
    "test-runner": "mtp",
    "coverage-analysis": "off",
    "reporters": [
      "html",
      "cleartext"
    ],
    "report-file-name": "index",
    "thresholds": {
      "high": 80,
      "low": 60,
      "break": 0
    },
    "mutate": [
      "!**/obj/**/*.cs",
      "!**/bin/**/*.cs",
      "!**/*.g.cs"
    ]
  }
}
